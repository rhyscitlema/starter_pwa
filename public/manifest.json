{
	"manifest_version": 3,
	"version": "1.0.0",
	"short_name": "Starter PWA",
	"name": "Starter Progressive Web App",
	"description": "A minimal starter template for future PWA projects using Spart.",
	"start_url": "/app",
	"id": "/?pwa=1",
	"display": "standalone",
	"background_color": "white",
	"theme_color": "#333",
	"icons": [
		{
			"src": "/favicon.ico",
			"sizes": "16x16 32x32 48x48 64x64",
			"type": "image/x-icon"
		},
		{
			"src": "/icons/logo-192x192.png",
			"sizes": "192x192",
			"type": "image/png"
		},
		{
			"src": "/icons/logo-512x512.png",
			"sizes": "512x512",
			"type": "image/png"
		}
	]
}
